def extract_patient_id_from_image(path: Path):
    name = path.name
    if name.startswith("._"):
        return None
    m = re.match(r"(colon_\d+)_0000\.nii(\.gz)?$", name)
    if m:
        return m.group(1)
    m = re.match(r"(colon_\d+)", name)
    return m.group(1) if m else None

def extract_patient_id_from_label(path: Path):
    name = path.name
    if name.startswith("._"):
        return None
    m = re.match(r"(colon_\d+)\.nii(\.gz)?$", name)
    if m:
        return m.group(1)
    m = re.match(r"(colon_\d+)", name)
    return m.group(1) if m else None

def build_pairs(data_path):
    images_dir = Path(data_path) / "imagesTr"
    labels_dir = Path(data_path) / "labelsTr"

    image_files = sorted([p for p in images_dir.glob("*.nii*") if not p.name.startswith("._")])
    label_files = sorted([p for p in labels_dir.glob("*.nii*") if not p.name.startswith("._")])

    image_map = {}
    for p in image_files:
        pid = extract_patient_id_from_image(p)
        if pid is not None:
            image_map[pid] = str(p)

    label_map = {}
    for p in label_files:
        pid = extract_patient_id_from_label(p)
        if pid is not None:
            label_map[pid] = str(p)

    common_ids = sorted(set(image_map.keys()) & set(label_map.keys()))
    pairs = [{"patient_id": pid, "image": image_map[pid], "label": label_map[pid]} for pid in common_ids]
    return pairs

def save_json(obj, path):
    """Sauvegarde JSON avec conversion automatique des types numpy"""
    def convert(o):
        if isinstance(o, np.integer):
            return int(o)
        if isinstance(o, np.floating):
            return float(o)
        if isinstance(o, np.ndarray):
            return o.tolist()
        return o
    
    with open(path, "w", encoding="utf-8") as f:
        json.dump(obj, f, indent=2, default=convert)

def autocast_context():
    return torch.amp.autocast("cuda", enabled=torch.cuda.is_available())

def pad_to_shape(arr, target_shape, constant_value=0):
    d, h, w = arr.shape
    td, th, tw = target_shape

    pad_d = max(0, td - d)
    pad_h = max(0, th - h)
    pad_w = max(0, tw - w)

    before_d = pad_d // 2
    after_d = pad_d - before_d
    before_h = pad_h // 2
    after_h = pad_h - before_h
    before_w = pad_w // 2
    after_w = pad_w - before_w

    arr_padded = np.pad(
        arr,
        ((before_d, after_d), (before_h, after_h), (before_w, after_w)),
        mode="constant",
        constant_values=constant_value,
    )
    return arr_padded

def compute_percentile_stats(image_path, percentiles=(5, 95)):
    try:
        img = nib.load(image_path).get_fdata(dtype=np.float32)
        p1 = float(np.percentile(img, percentiles[0]))
        p2 = float(np.percentile(img, percentiles[1]))
        if p2 - p1 < 1e-6:
            p2 = p1 + 1.0
        return p1, p2
    except Exception:
        return 0.0, 1.0

def normalize_volume_or_patch(arr, p_low, p_high, clip_range):
    arr = (arr - p_low) / (p_high - p_low + 1e-6)
    return np.clip(arr, clip_range[0], clip_range[1])

def compute_starts(size, patch, stride):
    if size <= patch:
        return [0]
    starts = list(range(0, size - patch + 1, stride))
    last = size - patch
    if starts[-1] != last:
        starts.append(last)
    return starts

# ==================== MÉTRIQUES ====================

class SegmentationMetrics3D:
    def __init__(self, threshold=0.4):
        self.threshold = threshold
        self.reset()

    def reset(self):
        self.dice_scores = []
        self.iou_scores = []
        self.precisions = []
        self.recalls = []
        self.specificities = []
        self.total_tp = 0
        self.total_fp = 0
        self.total_fn = 0
        self.total_tn = 0
        self.volumes_gt = []

    def update(self, pred_logits, target):
        pred = (torch.sigmoid(pred_logits) > self.threshold).float()

        for i in range(pred.size(0)):
            p = pred[i].view(-1)
            t = target[i].view(-1)

            tp = (p * t).sum().item()
            fp = (p * (1 - t)).sum().item()
            fn = ((1 - p) * t).sum().item()
            tn = ((1 - p) * (1 - t)).sum().item()

            self.total_tp += tp
            self.total_fp += fp
            self.total_fn += fn
            self.total_tn += tn

            smooth = 1e-6
            dice = (2 * tp + smooth) / (2 * tp + fp + fn + smooth)
            iou = (tp + smooth) / (tp + fp + fn + smooth)
            precision = (tp + smooth) / (tp + fp + smooth)
            recall = (tp + smooth) / (tp + fn + smooth)
            specificity = (tn + smooth) / (tn + fp + smooth)

            self.dice_scores.append(dice)
            self.iou_scores.append(iou)
            self.precisions.append(precision)
            self.recalls.append(recall)
            self.specificities.append(specificity)
            self.volumes_gt.append(tp + fn)

    def get_metrics(self):
        return {
            "dice": float(np.mean(self.dice_scores)) if self.dice_scores else 0.0,
            "dice_std": float(np.std(self.dice_scores)) if self.dice_scores else 0.0,
            "iou": float(np.mean(self.iou_scores)) if self.iou_scores else 0.0,
            "precision": float(np.mean(self.precisions)) if self.precisions else 0.0,
            "recall": float(np.mean(self.recalls)) if self.recalls else 0.0,
            "specificity": float(np.mean(self.specificities)) if self.specificities else 0.0,
            "total_tp": int(self.total_tp),
            "total_fp": int(self.total_fp),
            "total_fn": int(self.total_fn),
            "total_tn": int(self.total_tn),
            "n_patches": len(self.dice_scores),
            "n_patches_with_tumor": int(len([v for v in self.volumes_gt if v > 0])),
        }

    def print_metrics(self, title="MÉTRIQUES"):
        m = self.get_metrics()
        print(f"\n{title} (seuil={self.threshold}):")
        print(f"  Dice        : {m['dice']:.4f} ± {m['dice_std']:.4f}")
        print(f"  IoU         : {m['iou']:.4f}")
        print(f"  Precision   : {m['precision']:.4f}")
        print(f"  Recall      : {m['recall']:.4f}")
        print(f"  Specificity : {m['specificity']:.4f}")
        print(f"  Patches avec tumeur : {m['n_patches_with_tumor']}/{m['n_patches']}")

# ==================== LOSS ====================

class CombinedLoss3D(nn.Module):
    def __init__(self, bce_weight=0.4, dice_weight=0.6):
        super().__init__()
        self.bce_weight = bce_weight
        self.dice_weight = dice_weight
        self.bce = nn.BCEWithLogitsLoss()

    def dice_loss(self, pred, target, smooth=1e-6):
        pred = torch.sigmoid(pred)
        intersection = (pred * target).sum(dim=(2, 3, 4))
        union = pred.sum(dim=(2, 3, 4)) + target.sum(dim=(2, 3, 4))
        dice = (2 * intersection + smooth) / (union + smooth)
        return 1 - dice.mean()

    def forward(self, pred, target):
        return self.bce_weight * self.bce(pred, target) + self.dice_weight * self.dice_loss(pred, target)

# ==================== MODÈLE COMPLET ====================

class ConvBlock3D(nn.Module):
    def __init__(self, in_c, out_c, dropout=0.1, depth=2):
        super().__init__()
        layers = []
        for i in range(depth):
            cin = in_c if i == 0 else out_c
            layers.append(nn.Conv3d(cin, out_c, 3, padding=1))
            layers.append(nn.BatchNorm3d(out_c))
            layers.append(nn.ReLU(inplace=True))
            if i < depth - 1:
                layers.append(nn.Dropout3d(dropout))
        self.block = nn.Sequential(*layers)

    def forward(self, x):
        return self.block(x)

class UNet3D(nn.Module):
    def __init__(self, in_channels=1, out_channels=1, features=(24, 48, 96, 192)):
        super().__init__()
        f = list(features)

        self.enc1 = ConvBlock3D(in_channels, f[0], depth=2)
        self.enc2 = ConvBlock3D(f[0], f[1], depth=2)
        self.enc3 = ConvBlock3D(f[1], f[2], depth=2)
        self.enc4 = ConvBlock3D(f[2], f[3], depth=2)

        self.pool = nn.MaxPool3d(2)
        self.bottleneck = ConvBlock3D(f[3], f[3] * 2, depth=2)

        self.up4 = nn.ConvTranspose3d(f[3] * 2, f[3], 2, 2)
        self.dec4 = ConvBlock3D(f[3] * 2, f[3], depth=2)

        self.up3 = nn.ConvTranspose3d(f[3], f[2], 2, 2)
        self.dec3 = ConvBlock3D(f[2] * 2, f[2], depth=2)

        self.up2 = nn.ConvTranspose3d(f[2], f[1], 2, 2)
        self.dec2 = ConvBlock3D(f[1] * 2, f[1], depth=2)

        self.up1 = nn.ConvTranspose3d(f[1], f[0], 2, 2)
        self.dec1 = ConvBlock3D(f[0] * 2, f[0], depth=2)

        self.final = nn.Conv3d(f[0], out_channels, 1)

        self._init_weights()

    def _init_weights(self):
        for m in self.modules():
            if isinstance(m, (nn.Conv3d, nn.ConvTranspose3d)):
                nn.init.kaiming_normal_(m.weight, mode="fan_out", nonlinearity="relu")
                if m.bias is not None:
                    nn.init.constant_(m.bias, 0)
            elif isinstance(m, nn.BatchNorm3d):
                nn.init.constant_(m.weight, 1)
                nn.init.constant_(m.bias, 0)

    def forward(self, x):
        e1 = self.enc1(x)
        e2 = self.enc2(self.pool(e1))
        e3 = self.enc3(self.pool(e2))
        e4 = self.enc4(self.pool(e3))

        b = self.bottleneck(self.pool(e4))

        d4 = self.up4(b)
        if d4.shape[2:] != e4.shape[2:]:
            d4 = F.interpolate(d4, size=e4.shape[2:], mode="trilinear", align_corners=False)
        d4 = self.dec4(torch.cat([d4, e4], dim=1))

        d3 = self.up3(d4)
        if d3.shape[2:] != e3.shape[2:]:
            d3 = F.interpolate(d3, size=e3.shape[2:], mode="trilinear", align_corners=False)
        d3 = self.dec3(torch.cat([d3, e3], dim=1))

        d2 = self.up2(d3)
        if d2.shape[2:] != e2.shape[2:]:
            d2 = F.interpolate(d2, size=e2.shape[2:], mode="trilinear", align_corners=False)
        d2 = self.dec2(torch.cat([d2, e2], dim=1))

        d1 = self.up1(d2)
        if d1.shape[2:] != e1.shape[2:]:
            d1 = F.interpolate(d1, size=e1.shape[2:], mode="trilinear", align_corners=False)
        d1 = self.dec1(torch.cat([d1, e1], dim=1))

        return self.final(d1)

