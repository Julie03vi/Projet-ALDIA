class ColonDataset3D(Dataset):
    def __init__(self, pairs, phase="train", norm_stats=None):
        self.pairs = pairs
        self.phase = phase
        self.patch_size = config.PATCH_SIZE
        self.samples_per_volume = config.SAMPLES_PER_VOLUME if phase == "train" else max(1, config.SAMPLES_PER_VOLUME // 2)
        self.augment = config.USE_AUGMENTATION and phase == "train"
        self.tumor_ratio = config.TUMOR_RATIO
        self.min_tumor_voxels = config.MIN_TUMOR_VOXELS

        print(f"\nChargement dataset {phase} : {len(self.pairs)} volumes")

        self.volume_stats = {} if norm_stats is None else norm_stats
        self.volume_shapes = []
        self.small_volumes = []
        self.patches = []

        for vol_idx, pair in enumerate(self.pairs):
            try:
                img_nib = nib.load(pair["image"])
                mask_nib = nib.load(pair["label"])

                img_shape = img_nib.shape
                mask_shape = mask_nib.shape

                if img_shape != mask_shape:
                    print(f"⚠️ Shape différente pour {pair['patient_id']} : image {img_shape}, label {mask_shape}")
                    continue

                self.volume_shapes.append(img_shape)
                d, h, w = img_shape

                if d < self.patch_size[0] or h < self.patch_size[1] or w < self.patch_size[2]:
                    self.small_volumes.append(vol_idx)

                if norm_stats is None:
                    self.volume_stats[vol_idx] = compute_percentile_stats(pair["image"], config.NORM_PERCENTILES)

            except Exception as e:
                print(f"❌ Erreur lecture {pair['patient_id']} : {e}")
                self.volume_shapes.append(None)
                if norm_stats is None:
                    self.volume_stats[vol_idx] = (0.0, 1.0)

        print(f"Volumes nécessitant padding : {len(self.small_volumes)}")

        self.patches = self._generate_patches()

        if phase == "train":
            random.shuffle(self.patches)

        print(f"Nombre de patches {phase} : {len(self.patches)}")

    def _generate_patches(self):
        patches = []
        pd, ph, pw = self.patch_size

        for vol_idx, pair in enumerate(tqdm(self.pairs, desc=f"Patches {self.phase}")):
            try:
                mask = nib.load(pair["label"]).get_fdata(dtype=np.float32)
                d, h, w = mask.shape

                max_z = max(0, d - pd)
                max_y = max(0, h - ph)
                max_x = max(0, w - pw)

                tumor_voxels = np.where(mask > 0)
                has_tumor = len(tumor_voxels[0]) > 0

                if self.phase == "train" and has_tumor:
                    n_tumor = int(self.samples_per_volume * self.tumor_ratio)
                    n_background = self.samples_per_volume - n_tumor

                    tumor_found = 0
                    attempts = 0
                    max_attempts = max(50, n_tumor * 30)

                    while tumor_found < n_tumor and attempts < max_attempts:
                        attempts += 1
                        ridx = np.random.randint(len(tumor_voxels[0]))
                        cz, cy, cx = tumor_voxels[0][ridx], tumor_voxels[1][ridx], tumor_voxels[2][ridx]

                        z = max(0, min(cz - pd // 2, max_z)) if max_z > 0 else 0
                        y = max(0, min(cy - ph // 2, max_y)) if max_y > 0 else 0
                        x = max(0, min(cx - pw // 2, max_x)) if max_x > 0 else 0

                        z_end = min(z + pd, d)
                        y_end = min(y + ph, h)
                        x_end = min(x + pw, w)

                        patch_mask = mask[z:z_end, y:y_end, x:x_end]
                        if (patch_mask > 0).sum() >= self.min_tumor_voxels:
                            patches.append((vol_idx, z, y, x, z_end - z, y_end - y, x_end - x))
                            tumor_found += 1

                    for _ in range(n_background):
                        z = np.random.randint(0, max_z + 1) if max_z > 0 else 0
                        y = np.random.randint(0, max_y + 1) if max_y > 0 else 0
                        x = np.random.randint(0, max_x + 1) if max_x > 0 else 0

                        z_end = min(z + pd, d)
                        y_end = min(y + ph, h)
                        x_end = min(x + pw, w)

                        patches.append((vol_idx, z, y, x, z_end - z, y_end - y, x_end - x))

                else:
                    step_z = max(1, d // 4)
                    step_y = max(1, h // 4)
                    step_x = max(1, w // 4)

                    z_positions = list(range(0, d, step_z))
                    y_positions = list(range(0, h, step_y))
                    x_positions = list(range(0, w, step_x))

                    if len(z_positions) == 0:
                        z_positions = [0]
                    if len(y_positions) == 0:
                        y_positions = [0]
                    if len(x_positions) == 0:
                        x_positions = [0]

                    for z in z_positions:
                        for y in y_positions:
                            for x in x_positions:
                                z = min(z, max(0, d - 1))
                                y = min(y, max(0, h - 1))
                                x = min(x, max(0, w - 1))

                                z_end = min(z + pd, d)
                                y_end = min(y + ph, h)
                                x_end = min(x + pw, w)

                                patches.append((vol_idx, z, y, x, z_end - z, y_end - y, x_end - x))

            except Exception as e:
                print(f"⚠️ Erreur génération patches {pair['patient_id']} : {e}")

        return patches

    def __len__(self):
        return len(self.patches)

    def __getitem__(self, idx):
        vol_idx, z, y, x, actual_d, actual_h, actual_w = self.patches[idx]
        pair = self.pairs[vol_idx]
        pd, ph, pw = self.patch_size

        try:
            img = nib.load(pair["image"])
            mask = nib.load(pair["label"])

            z_end = z + actual_d
            y_end = y + actual_h
            x_end = x + actual_w

            img_patch = np.array(img.dataobj[z:z_end, y:y_end, x:x_end], dtype=np.float32)
            mask_patch = np.array(mask.dataobj[z:z_end, y:y_end, x:x_end], dtype=np.float32)

            img_patch = pad_to_shape(img_patch, (pd, ph, pw), constant_value=0)
            mask_patch = pad_to_shape(mask_patch, (pd, ph, pw), constant_value=0)

            if vol_idx in self.volume_stats:
                p5, p95 = self.volume_stats[vol_idx]
            else:
                p5, p95 = 0.0, 1.0

            img_patch = normalize_volume_or_patch(img_patch, p5, p95, config.NORM_CLIP)
            mask_patch = (mask_patch > 0).astype(np.float32)

            # Augmentation
            if self.augment and np.random.random() < config.AUGMENT_PROB:
                if np.random.random() > 0.5:
                    axis = np.random.randint(0, 3)
                    img_patch = np.flip(img_patch, axis=axis).copy()
                    mask_patch = np.flip(mask_patch, axis=axis).copy()
                
                if np.random.random() > 0.7:
                    k = np.random.randint(1, 4)
                    img_patch = np.rot90(img_patch, k, axes=(1, 2)).copy()
                    mask_patch = np.rot90(mask_patch, k, axes=(1, 2)).copy()

            return (
                torch.from_numpy(img_patch).unsqueeze(0).float(),
                torch.from_numpy(mask_patch).unsqueeze(0).float(),
            )

        except Exception as e:
            print(f"⚠️ Erreur patch {idx} ({pair['patient_id']}) : {e}")
            return (
                torch.zeros((1, pd, ph, pw), dtype=torch.float32),
                torch.zeros((1, pd, ph, pw), dtype=torch.float32),
            )

