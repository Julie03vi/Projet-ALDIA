# ==================== INFÉRENCE VOLUME ENTIER ====================

def predict_full_volume(model, pair, norm_stats, threshold=0.4):
    """
    Prédiction sur volume entier avec les stats du train
    """
    img_nib = nib.load(pair["image"])
    img = img_nib.get_fdata(dtype=np.float32)

    # Utiliser les stats du train SAUVEGARDÉES
    patient_id = pair["patient_id"]
    if patient_id in norm_stats:
        p5, p95 = norm_stats[patient_id]
    else:
        # Fallback si les stats ne sont pas trouvées
        p5, p95 = compute_percentile_stats(pair["image"], config.NORM_PERCENTILES)

    img_norm = normalize_volume_or_patch(img, p5, p95, config.NORM_CLIP)

    d, h, w = img_norm.shape
    pd, ph, pw = config.PATCH_SIZE

    stride_z = max(1, pd // config.VIS_STRIDE_DIV)
    stride_y = max(1, ph // config.VIS_STRIDE_DIV)
    stride_x = max(1, pw // config.VIS_STRIDE_DIV)

    z_starts = compute_starts(d, pd, stride_z)
    y_starts = compute_starts(h, ph, stride_y)
    x_starts = compute_starts(w, pw, stride_x)

    prob_sum = np.zeros((d, h, w), dtype=np.float32)
    prob_count = np.zeros((d, h, w), dtype=np.float32)

    batch_patches = []
    batch_positions = []

    model.eval()
    with torch.no_grad():
        for z in z_starts:
            for y in y_starts:
                for x in x_starts:
                    patch = img_norm[z:min(z + pd, d), y:min(y + ph, h), x:min(x + pw, w)]
                    patch = pad_to_shape(patch, (pd, ph, pw), constant_value=0)

                    batch_patches.append(patch)
                    batch_positions.append((z, y, x))

                    if len(batch_patches) >= config.VIS_BATCH_SIZE:
                        batch_tensor = torch.from_numpy(np.array(batch_patches)).unsqueeze(1).float().to(device)

                        with autocast_context():
                            outputs = model(batch_tensor)
                            preds = torch.sigmoid(outputs).detach().cpu().numpy()[:, 0]

                        for j, (pz, py, px) in enumerate(batch_positions):
                            dz = min(pd, d - pz)
                            dy = min(ph, h - py)
                            dx = min(pw, w - px)

                            prob_sum[pz:pz+dz, py:py+dy, px:px+dx] += preds[j][:dz, :dy, :dx]
                            prob_count[pz:pz+dz, py:py+dy, px:px+dx] += 1.0

                        batch_patches = []
                        batch_positions = []

        if batch_patches:
            batch_tensor = torch.from_numpy(np.array(batch_patches)).unsqueeze(1).float().to(device)

            with autocast_context():
                outputs = model(batch_tensor)
                preds = torch.sigmoid(outputs).detach().cpu().numpy()[:, 0]

            for j, (pz, py, px) in enumerate(batch_positions):
                dz = min(pd, d - pz)
                dy = min(ph, h - py)
                dx = min(pw, w - px)

                prob_sum[pz:pz+dz, py:py+dy, px:px+dx] += preds[j][:dz, :dy, :dx]
                prob_count[pz:pz+dz, py:py+dy, px:px+dx] += 1.0

    avg_prob = prob_sum / np.maximum(prob_count, 1e-6)
    avg_prob = gaussian_filter(avg_prob, sigma=0.5)
    pred_binary = (avg_prob > threshold).astype(np.float32)

    gt = nib.load(pair["label"]).get_fdata(dtype=np.float32)
    gt = (gt > 0).astype(np.float32)

    return img, gt, avg_prob, pred_binary

# ==================== VISUALISATION 3 AXES ====================

def visualize_full_volume_3axes(model, pair, norm_stats, threshold=0.4):
    """
    Visualisation sur les 3 axes pour un patient
    """
    # Prédiction complète
    img, gt, prob, pred = predict_full_volume(model, pair, norm_stats, threshold)
    
    # Dimensions
    d, h, w = img.shape
    
    # Trouver les coupes avec le plus de tumeur
    gt_sum_z = gt.sum(axis=(1, 2))
    gt_sum_y = gt.sum(axis=(0, 2))
    gt_sum_x = gt.sum(axis=(0, 1))
    
    # Vérifier s'il y a des tumeurs
    has_tumor_z = gt_sum_z.max() > 0
    has_tumor_y = gt_sum_y.max() > 0
    has_tumor_x = gt_sum_x.max() > 0
    has_tumor = has_tumor_z or has_tumor_y or has_tumor_x
    
    # Coupes les plus représentatives
    best_z = np.argmax(gt_sum_z) if has_tumor_z else d // 2
    best_y = np.argmax(gt_sum_y) if has_tumor_y else h // 2
    best_x = np.argmax(gt_sum_x) if has_tumor_x else w // 2
    
    # Créer la figure
    fig, axes = plt.subplots(3, 4, figsize=(20, 15))
    
    # Titres des colonnes
    axes[0, 0].set_title("Image", fontsize=14, fontweight='bold')
    axes[0, 1].set_title("Vérité terrain", fontsize=14, fontweight='bold')
    axes[0, 2].set_title("Prédiction", fontsize=14, fontweight='bold')
    axes[0, 3].set_title("Superposition", fontsize=14, fontweight='bold')
    
    # ===== AXE Z =====
    img_slice_z = img[best_z]
    gt_slice_z = gt[best_z]
    prob_slice_z = prob[best_z]
    pred_slice_z = pred[best_z]
    
    img_disp_z = (img_slice_z - img_slice_z.min()) / (img_slice_z.max() - img_slice_z.min() + 1e-6)
    
    axes[0, 0].imshow(img_disp_z, cmap='gray', origin='lower')
    axes[0, 0].set_ylabel(f"Axe Z\n(coupe {best_z}/{d-1})", fontsize=12, fontweight='bold')
    
    axes[0, 1].imshow(gt_slice_z, cmap='Reds', vmin=0, vmax=1, origin='lower')
    im = axes[0, 2].imshow(prob_slice_z, cmap='hot', vmin=0, vmax=1, origin='lower')
    
    overlay_z = np.zeros((*img_slice_z.shape, 3))
    overlay_z[..., 0] = pred_slice_z
    overlay_z[..., 1] = gt_slice_z
    overlay_z[..., 2] = img_disp_z * 0.3
    axes[0, 3].imshow(overlay_z, origin='lower')
    
    # ===== AXE Y =====
    img_slice_y = img[:, best_y, :]
    gt_slice_y = gt[:, best_y, :]
    prob_slice_y = prob[:, best_y, :]
    pred_slice_y = pred[:, best_y, :]
    
    img_disp_y = (img_slice_y - img_slice_y.min()) / (img_slice_y.max() - img_slice_y.min() + 1e-6)
    
    axes[1, 0].imshow(img_disp_y, cmap='gray', origin='lower')
    axes[1, 0].set_ylabel(f"Axe Y\n(coupe {best_y}/{h-1})", fontsize=12, fontweight='bold')
    
    axes[1, 1].imshow(gt_slice_y, cmap='Reds', vmin=0, vmax=1, origin='lower')
    axes[1, 2].imshow(prob_slice_y, cmap='hot', vmin=0, vmax=1, origin='lower')
    
    overlay_y = np.zeros((*img_slice_y.shape, 3))
    overlay_y[..., 0] = pred_slice_y
    overlay_y[..., 1] = gt_slice_y
    overlay_y[..., 2] = img_disp_y * 0.3
    axes[1, 3].imshow(overlay_y, origin='lower')
    
    # ===== AXE X =====
    img_slice_x = img[:, :, best_x]
    gt_slice_x = gt[:, :, best_x]
    prob_slice_x = prob[:, :, best_x]
    pred_slice_x = pred[:, :, best_x]
    
    img_disp_x = (img_slice_x - img_slice_x.min()) / (img_slice_x.max() - img_slice_x.min() + 1e-6)
    
    axes[2, 0].imshow(img_disp_x, cmap='gray', origin='lower')
    axes[2, 0].set_ylabel(f"Axe X\n(coupe {best_x}/{w-1})", fontsize=12, fontweight='bold')
    axes[2, 0].set_xlabel("Y →", fontsize=10)
    
    axes[2, 1].imshow(gt_slice_x, cmap='Reds', vmin=0, vmax=1, origin='lower')
    axes[2, 2].imshow(prob_slice_x, cmap='hot', vmin=0, vmax=1, origin='lower')
    
    overlay_x = np.zeros((*img_slice_x.shape, 3))
    overlay_x[..., 0] = pred_slice_x
    overlay_x[..., 1] = gt_slice_x
    overlay_x[..., 2] = img_disp_x * 0.3
    axes[2, 3].imshow(overlay_x, origin='lower')
    
    # Masquer les axes
    for i in range(3):
        for j in range(4):
            axes[i, j].axis('off')
    
    # Colorbar
    cbar_ax = fig.add_axes([0.92, 0.15, 0.01, 0.7])
    plt.colorbar(im, cax=cbar_ax, label='Probabilité')
    
    # Titre
    status = "AVEC tumeur" if has_tumor else "SANS tumeur"
    intersection = (pred * gt).sum()
    union = pred.sum() + gt.sum()
    dice = (2 * intersection) / (union + 1e-6)
    
    plt.suptitle(f"{pair['patient_id']} - {status} - Dice: {dice:.4f}", fontsize=16, fontweight='bold')
    plt.tight_layout(rect=[0, 0, 0.90, 0.96])
    
    # Sauvegarde
    out_path = f"{config.PREDICTIONS_DIR}/{pair['patient_id']}_3axes.png"
    plt.savefig(out_path, dpi=150, bbox_inches='tight')
    plt.close()
    
    # Sauvegarde NIfTI
    pred_nii = nib.Nifti1Image(pred.astype(np.uint8), affine=nib.load(pair["image"]).affine)
    nib.save(pred_nii, f"{config.PREDICTIONS_DIR}/{pair['patient_id']}_prediction.nii.gz")
    
    print(f"  Dice: {dice:.4f} - {status}")
    print(f"  ✅ Sauvegardé: {out_path}")
    
    return float(dice)

# ==================== MAIN ====================

def main():
    print("\n" + "=" * 80)
    print("DÉMARRAGE DE L'ENTRAÎNEMENT - VERSION 4H")
    print("=" * 80)

    print("Device :", device)

    if device.type == "cuda":
        gc.collect()
        torch.cuda.empty_cache()
        print(f"Mémoire GPU initiale : {torch.cuda.memory_allocated() / 1e9:.2f} GB")

    # ===== 1. PAIRES =====
    pairs = build_pairs(config.DATA_PATH)
    print(f"\nPaires image/label trouvées : {len(pairs)}")

    if len(pairs) == 0:
        raise ValueError("Aucune paire image/label trouvée.")

    patient_ids = [p["patient_id"] for p in pairs]

    train_ids, temp_ids = train_test_split(
        patient_ids,
        train_size=config.TRAIN_RATIO,
        random_state=config.RANDOM_SEED,
        shuffle=True,
    )

    val_ratio_rel = config.VAL_RATIO / (config.VAL_RATIO + config.TEST_RATIO)
    val_ids, test_ids = train_test_split(
        temp_ids,
        train_size=val_ratio_rel,
        random_state=config.RANDOM_SEED,
        shuffle=True,
    )

    train_pairs = [p for p in pairs if p["patient_id"] in train_ids]
    val_pairs = [p for p in pairs if p["patient_id"] in val_ids]
    test_pairs = [p for p in pairs if p["patient_id"] in test_ids]

    split_info = {
        "train_ids": train_ids,
        "val_ids": val_ids,
        "test_ids": test_ids,
        "train_files": train_pairs,
        "val_files": val_pairs,
        "test_files": test_pairs,
        "random_seed": config.RANDOM_SEED,
    }
    save_json(split_info, f"{config.CONTEXT_DIR}/split_indices.json")

    print("\nSplit :")
    print("Train :", len(train_pairs), "patients")
    print("Val   :", len(val_pairs), "patients")
    print("Test  :", len(test_pairs), "patients")

    # ===== 2. DATASETS =====
    print("\nCréation des datasets...")
    train_dataset = ColonDataset3D(train_pairs, phase="train")
    val_dataset = ColonDataset3D(val_pairs, phase="val", norm_stats=train_dataset.volume_stats)
    test_dataset = ColonDataset3D(test_pairs, phase="test", norm_stats=train_dataset.volume_stats)

    # Sauvegarder les stats de normalisation du train
    norm_stats_for_vis = {}
    for i, pair in enumerate(train_pairs):
        if i in train_dataset.volume_stats:
            norm_stats_for_vis[pair["patient_id"]] = train_dataset.volume_stats[i]

    save_json(norm_stats_for_vis, f"{config.CONTEXT_DIR}/normalization_stats.json")

    train_loader = DataLoader(
        train_dataset,
        batch_size=config.BATCH_SIZE,
        shuffle=True,
        num_workers=config.NUM_WORKERS,
        pin_memory=config.PIN_MEMORY and torch.cuda.is_available(),
    )
    val_loader = DataLoader(
        val_dataset,
        batch_size=config.BATCH_SIZE,
        shuffle=False,
        num_workers=config.NUM_WORKERS,
        pin_memory=config.PIN_MEMORY and torch.cuda.is_available(),
    )
    test_loader = DataLoader(
        test_dataset,
        batch_size=config.BATCH_SIZE,
        shuffle=False,
        num_workers=config.NUM_WORKERS,
        pin_memory=config.PIN_MEMORY and torch.cuda.is_available(),
    )

    # ===== 3. MODÈLE =====
    print("\nCréation du modèle...")
    model = UNet3D(
        in_channels=config.IN_CHANNELS,
        out_channels=config.OUT_CHANNELS,
        features=config.FEATURES,
    ).to(device)

    print(f"Paramètres : {sum(p.numel() for p in model.parameters()):,}")

    criterion = CombinedLoss3D(config.BCE_WEIGHT, config.DICE_WEIGHT)
    optimizer = optim.AdamW(model.parameters(), lr=config.LR, weight_decay=config.WEIGHT_DECAY)
    scheduler = optim.lr_scheduler.ReduceLROnPlateau(optimizer, mode="max", factor=0.5, patience=5)
    scaler = torch.amp.GradScaler("cuda", enabled=torch.cuda.is_available())

    history = {"train_loss": [], "val_loss": [], "train_dice": [], "val_dice": []}

    best_dice = 0.0
    patience_counter = 0
    start_time = time.time()

    print("\n" + "=" * 80)
    print("ENTRAÎNEMENT")
    print("=" * 80)

    for epoch in range(config.EPOCHS):
        print(f"\nÉpoque {epoch + 1}/{config.EPOCHS}")
        epoch_start = time.time()

        if device.type == "cuda":
            gc.collect()
            torch.cuda.empty_cache()

        # ----- TRAIN -----
        model.train()
        train_loss = 0.0
        train_metrics = SegmentationMetrics3D(threshold=config.SLICE_THRESHOLD)
        optimizer.zero_grad(set_to_none=True)

        for batch_idx, (images, masks) in enumerate(tqdm(train_loader, desc="Train", leave=False)):
            images = images.to(device, non_blocking=True)
            masks = masks.to(device, non_blocking=True)

            with autocast_context():
                outputs = model(images)
                loss = criterion(outputs, masks)

            scaler.scale(loss).backward()

            if (batch_idx + 1) % config.GRAD_ACCUM_STEPS == 0 or (batch_idx + 1) == len(train_loader):
                scaler.step(optimizer)
                scaler.update()
                optimizer.zero_grad(set_to_none=True)

            train_loss += loss.item()
            train_metrics.update(outputs.detach(), masks)

        # ----- VAL -----
        model.eval()
        val_loss = 0.0
        val_metrics = SegmentationMetrics3D(threshold=config.SLICE_THRESHOLD)

        with torch.no_grad():
            for images, masks in tqdm(val_loader, desc="Val", leave=False):
                images = images.to(device, non_blocking=True)
                masks = masks.to(device, non_blocking=True)

                with autocast_context():
                    outputs = model(images)
                    loss = criterion(outputs, masks)

                val_loss += loss.item()
                val_metrics.update(outputs, masks)

        avg_train_loss = train_loss / max(len(train_loader), 1)
        avg_val_loss = val_loss / max(len(val_loader), 1)

        train_m = train_metrics.get_metrics()
        val_m = val_metrics.get_metrics()

        history["train_loss"].append(avg_train_loss)
        history["val_loss"].append(avg_val_loss)
        history["train_dice"].append(train_m["dice"])
        history["val_dice"].append(val_m["dice"])

        epoch_time = time.time() - epoch_start

        print(f"Train - Loss: {avg_train_loss:.4f} | Dice: {train_m['dice']:.4f}")
        print(f"Val   - Loss: {avg_val_loss:.4f} | Dice: {val_m['dice']:.4f}")
        print(f"Temps : {epoch_time:.1f}s")

        if device.type == "cuda":
            print(f"Mémoire GPU : {torch.cuda.memory_allocated() / 1e9:.2f} GB")

        scheduler.step(val_m["dice"])

        if val_m["dice"] > best_dice + config.MIN_DELTA:
            best_dice = val_m["dice"]
            patience_counter = 0

            torch.save(
                {
                    "epoch": epoch,
                    "model_state_dict": model.state_dict(),
                    "optimizer_state_dict": optimizer.state_dict(),
                    "best_dice": best_dice,
                    "config": asdict(config),
                },
                f"{config.CHECKPOINT_DIR}/best_model.pth",
            )
            print(f"✅ Nouveau meilleur modèle : Dice val = {best_dice:.4f}")
        else:
            patience_counter += 1
            print(f"⏳ Patience : {patience_counter}/{config.PATIENCE}")

            if patience_counter >= config.PATIENCE:
                print("\n⏹️ Early stopping")
                break

    # ===== 4. ÉVALUATION =====
    print("\n" + "=" * 80)
    print("ÉVALUATION FINALE")
    print("=" * 80)

    checkpoint = torch.load(f"{config.CHECKPOINT_DIR}/best_model.pth", map_location=device)
    model.load_state_dict(checkpoint["model_state_dict"])
    model.eval()

    print("\nRecherche du meilleur seuil sur validation...")
    thresholds = [0.30, 0.35, 0.40, 0.45, 0.50]
    threshold_scores = []

    for thresh in thresholds:
        val_metrics = SegmentationMetrics3D(threshold=thresh)
        with torch.no_grad():
            for images, masks in tqdm(val_loader, desc=f"Val seuil={thresh}", leave=False):
                images = images.to(device, non_blocking=True)
                masks = masks.to(device, non_blocking=True)

                with autocast_context():
                    outputs = model(images)

                val_metrics.update(outputs, masks)

        m = val_metrics.get_metrics()
        print(f"Seuil {thresh:.2f} -> Dice={m['dice']:.4f} ± {m['dice_std']:.4f}")
        threshold_scores.append((thresh, m["dice"]))

    best_threshold, best_val_dice_thresh = max(threshold_scores, key=lambda x: x[1])
    print(f"\n🏆 Meilleur seuil validation : {best_threshold} (Dice={best_val_dice_thresh:.4f})")

    test_metrics = SegmentationMetrics3D(threshold=best_threshold)
    with torch.no_grad():
        for images, masks in tqdm(test_loader, desc="Test", leave=False):
            images = images.to(device, non_blocking=True)
            masks = masks.to(device, non_blocking=True)

            with autocast_context():
                outputs = model(images)

            test_metrics.update(outputs, masks)

    test_metrics.print_metrics("RÉSULTATS TEST")

    # ===== 5. VISUALISATIONS =====
    print("\n" + "=" * 80)
    print("GÉNÉRATION DES VISUALISATIONS 3 AXES")
    print("=" * 80)

    visualize_training(history)
    
    print(f"\n🖼️ Visualisation 3 axes pour {len(test_pairs)} patients...")
    volume_metrics = []
    
    for i, pair in enumerate(test_pairs):
        print(f"\nPatient {i+1}/{len(test_pairs)} : {pair['patient_id']}")
        dice = visualize_full_volume_3axes(model, pair, norm_stats_for_vis, threshold=best_threshold)
        volume_metrics.append({"patient": pair["patient_id"], "dice": dice})

    # ===== 6. SAUVEGARDE =====
    total_time = time.time() - start_time

    final_results = {
        "date": datetime.now().isoformat(),
        "best_val_dice_training": float(best_dice),
        "best_threshold": float(best_threshold),
        "best_val_dice_threshold_search": float(best_val_dice_thresh),
        "test_metrics": {k: float(v) if isinstance(v, (np.floating, np.integer)) else v 
                         for k, v in test_metrics.get_metrics().items()},
        "volume_metrics": volume_metrics,
        "total_time_hours": float(total_time / 3600.0),
        "total_epochs": len(history["train_loss"]),
        "config": asdict(config),
    }

    save_json(final_results, f"{config.OUTPUT_DIR}/final_results.json")
    pd.DataFrame(history).to_csv(f"{config.OUTPUT_DIR}/history.csv", index=False)
    pd.DataFrame(threshold_scores, columns=["threshold", "dice"]).to_csv(
        f"{config.TEST_DIR}/threshold_validation.csv", index=False
    )
    if volume_metrics:
        pd.DataFrame(volume_metrics).to_csv(f"{config.TEST_DIR}/volume_metrics.csv", index=False)

    print("\n" + "=" * 80)
    print("ENTRAÎNEMENT TERMINÉ")
    print("=" * 80)
    print("Output dir           :", config.OUTPUT_DIR)
    print("Best val Dice train  :", f"{best_dice:.4f}")
    print("Best threshold       :", best_threshold)
    print("Best test Dice       :", f"{test_metrics.get_metrics()['dice']:.4f}")
    print("Temps total          :", f"{total_time/3600:.2f} heures")
    print("Modèle               :", f"{config.CHECKPOINT_DIR}/best_model.pth")
    print("Courbes              :", f"{config.VISUALS_DIR}/courbes_entrainement.png")
    print("Visualisations 3 axes:", config.PREDICTIONS_DIR)
    print("=" * 80)

if __name__ == "__main__":
    main()
