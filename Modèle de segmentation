def extract_patient_id_from_image(path: Path):
    """
    Extrait l'ID patient d'un fichier image.
    Format attendu: colon_XXX_0000.nii.gz ou colon_XXX.nii.gz
    """
    name = path.name
    if name.startswith("._"):  # Ignore les fichiers cachés macOS
        return None
    m = re.match(r"(colon_\d+)_0000\.nii(\.gz)?$", name)
    if m:
        return m.group(1)
    m = re.match(r"(colon_\d+)", name)
    return m.group(1) if m else None

def extract_patient_id_from_label(path: Path):
    """
    Extrait l'ID patient d'un fichier label.
    Format attendu: colon_XXX.nii.gz
    """
    name = path.name
    if name.startswith("._"):  # Ignore les fichiers cachés macOS
        return None
    m = re.match(r"(colon_\d+)\.nii(\.gz)?$", name)
    if m:
        return m.group(1)
    m = re.match(r"(colon_\d+)", name)
    return m.group(1) if m else None

def build_pairs(data_path):
    """
    Construit les paires image/label pour tous les patients.
    Ne garde que les patients ayant à la fois une image et un label.
    """
    images_dir = Path(data_path) / "imagesTr"
    labels_dir = Path(data_path) / "labelsTr"

    # Récupération de tous les fichiers
    image_files = sorted([p for p in images_dir.glob("*.nii*") if not p.name.startswith("._")])
    label_files = sorted([p for p in labels_dir.glob("*.nii*") if not p.name.startswith("._")])

    # Création de dictionnaires ID -> chemin
    image_map = {}
    for p in image_files:
        pid = extract_patient_id_from_image(p)
        if pid is not None:
            image_map[pid] = str(p)

    label_map = {}
    for p in label_files:
        pid = extract_patient_id_from_label(p)
        if pid is not None:
            label_map[pid] = str(p)

    # Intersection des IDs présents dans les deux dictionnaires
    common_ids = sorted(set(image_map.keys()) & set(label_map.keys()))
    pairs = [{"patient_id": pid, "image": image_map[pid], "label": label_map[pid]} for pid in common_ids]
    return pairs

def save_json(obj, path):
    """
    Sauvegarde un objet en JSON avec conversion automatique des types numpy.
    Utile pour sauvegarder les métriques et la configuration.
    """
    def convert(o):
        if isinstance(o, np.integer):
            return int(o)
        if isinstance(o, np.floating):
            return float(o)
        if isinstance(o, np.ndarray):
            return o.tolist()
        return o
    
    with open(path, "w", encoding="utf-8") as f:
        json.dump(obj, f, indent=2, default=convert)

